rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isString(value) {
      return value is string && value.size() > 0;
    }

    function isOptionalString(value) {
      return value is string;
    }

    function isNumber(value) {
      return value is number;
    }

    function isBoolean(value) {
      return value is bool;
    }

    function isValidMemberCreate() {
      return request.resource.data.keys().hasOnly([
        'id',
        'username',
        'email',
        'phone',
        'invitationCode',
        'referredBy',
        'level',
        'balance',
        'totalOrders',
        'lastLogin',
        'accountPassword',
        'withdrawalPassword'
      ])
      && isString(request.resource.data.id)
      && isString(request.resource.data.username)
      && isString(request.resource.data.email)
      && isString(request.resource.data.phone)
      && isString(request.resource.data.invitationCode)
      && isString(request.resource.data.referredBy)
      && request.resource.data.level in ['Starter', 'Silver', 'Gold', 'VIP']
      && isNumber(request.resource.data.balance)
      && request.resource.data.balance >= 0
      && request.resource.data.totalOrders == 0
      && isString(request.resource.data.lastLogin)
      && isString(request.resource.data.accountPassword)
      && isString(request.resource.data.withdrawalPassword);
    }

    function isValidProduct() {
      return request.resource.data.keys().hasOnly([
        'id',
        'code',
        'name',
        'price',
        'commission',
        'requiredBalance',
        'quantity',
        'category',
        'image'
      ])
      && isString(request.resource.data.id)
      && isString(request.resource.data.code)
      && isString(request.resource.data.name)
      && isString(request.resource.data.category)
      && isString(request.resource.data.image)
      && isNumber(request.resource.data.price)
      && isNumber(request.resource.data.commission)
      && isNumber(request.resource.data.requiredBalance)
      && isNumber(request.resource.data.quantity)
      && request.resource.data.price >= 0
      && request.resource.data.commission >= 0
      && request.resource.data.requiredBalance >= 0
      && request.resource.data.quantity >= 0;
    }

    function isValidBank() {
      return request.resource.data.keys().hasOnly([
        'id',
        'bank',
        'accountName',
        'accountNumber',
        'minDeposit',
        'active'
      ])
      && isString(request.resource.data.id)
      && isString(request.resource.data.bank)
      && isString(request.resource.data.accountName)
      && isString(request.resource.data.accountNumber)
      && isNumber(request.resource.data.minDeposit)
      && isBoolean(request.resource.data.active)
      && request.resource.data.minDeposit >= 0;
    }

    function isValidOrder() {
      return request.resource.data.keys().hasOnly([
        'id',
        'referenceNumber',
        'memberId',
        'member',
        'admin',
        'productCode',
        'productName',
        'value',
        'commission',
        'requiredBalance',
        'status',
        'createdAt',
        'assignedAt',
        'completedAt'
      ])
      && isString(request.resource.data.id)
      && isString(request.resource.data.referenceNumber)
      && isString(request.resource.data.memberId)
      && isString(request.resource.data.member)
      && isString(request.resource.data.admin)
      && isOptionalString(request.resource.data.productCode)
      && isOptionalString(request.resource.data.productName)
      && isNumber(request.resource.data.value)
      && isNumber(request.resource.data.commission)
      && isNumber(request.resource.data.requiredBalance)
      && request.resource.data.status in ['waiting', 'assigned', 'completed', 'frozen']
      && isString(request.resource.data.createdAt)
      && isOptionalString(request.resource.data.assignedAt)
      && isOptionalString(request.resource.data.completedAt)
      && request.resource.data.value >= 0
      && request.resource.data.commission >= 0
      && request.resource.data.requiredBalance >= 0;
    }

    function isValidTransactionCreate() {
      return request.resource.data.keys().hasOnly([
        'id',
        'requestId',
        'member',
        'admin',
        'type',
        'amount',
        'status',
        'createdAt',
        'senderName',
        'proofName',
        'proofType'
      ])
      && isString(request.resource.data.id)
      && isString(request.resource.data.requestId)
      && isString(request.resource.data.member)
      && isString(request.resource.data.admin)
      && request.resource.data.type in ['topup', 'withdrawal']
      && isNumber(request.resource.data.amount)
      && request.resource.data.amount >= 10000
      && request.resource.data.status == 'pending'
      && isString(request.resource.data.createdAt)
      && isOptionalString(request.resource.data.senderName)
      && isOptionalString(request.resource.data.proofName)
      && isOptionalString(request.resource.data.proofType)
      && (
        request.resource.data.type == 'withdrawal'
        || (
          isString(request.resource.data.senderName)
          && isString(request.resource.data.proofName)
          && isString(request.resource.data.proofType)
        )
      );
    }

    function isValidTransactionStatusUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
      && resource.data.status == 'pending'
      && request.resource.data.status in ['approved', 'rejected'];
    }

    function isValidMemberBalanceUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['balance', 'totalOrders'])
      && isNumber(request.resource.data.balance)
      && request.resource.data.balance >= 0
      && isNumber(request.resource.data.totalOrders)
      && request.resource.data.totalOrders >= resource.data.totalOrders;
    }

    function isValidStaffCreate() {
      return request.resource.data.keys().hasOnly([
        'id',
        'name',
        'code',
        'adminCode',
        'invitationCode',
        'registrationBonus',
        'registrations',
        'todayDeposits',
        'monthDeposits',
        'todayWithdrawals',
        'monthWithdrawals',
        'username',
        'password',
        'role'
      ])
      && isString(request.resource.data.id)
      && isString(request.resource.data.name)
      && isString(request.resource.data.code)
      && isString(request.resource.data.adminCode)
      && isString(request.resource.data.invitationCode)
      && isString(request.resource.data.username)
      && isString(request.resource.data.password)
      && request.resource.data.role in ['admin', 'employee']
      && isNumber(request.resource.data.registrationBonus)
      && isNumber(request.resource.data.registrations)
      && isNumber(request.resource.data.todayDeposits)
      && isNumber(request.resource.data.monthDeposits)
      && isNumber(request.resource.data.todayWithdrawals)
      && isNumber(request.resource.data.monthWithdrawals)
      && request.resource.data.registrations == 0
      && request.resource.data.registrationBonus >= 0
      && request.resource.data.todayDeposits == 0
      && request.resource.data.monthDeposits == 0
      && request.resource.data.todayWithdrawals == 0
      && request.resource.data.monthWithdrawals == 0;
    }

    match /members/{memberId} {
      allow read: if true;
      allow create: if request.resource.data.id == memberId && isValidMemberCreate();
      allow update: if isValidMemberBalanceUpdate();
      allow delete: if false;
    }

    match /admins/{adminId} {
      allow read: if true;
      allow create: if request.resource.data.id == adminId && isValidStaffCreate();
      allow update, delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if request.resource.data.id == productId && isValidProduct();
      allow delete: if false;
    }

    match /banks/{bankId} {
      allow read: if true;
      allow create, update: if request.resource.data.id == bankId && isValidBank();
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.resource.data.id == orderId && isValidOrder();
      allow update: if request.resource.data.id == orderId && isValidOrder();
      allow delete: if false;
    }

    match /transactions/{transactionId} {
      allow read: if true;
      allow create: if request.resource.data.id == transactionId && isValidTransactionCreate();
      allow update: if isValidTransactionStatusUpdate();
      allow delete: if false;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
